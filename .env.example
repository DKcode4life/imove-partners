# ─── Database ────────────────────────────────────────────────────────────────
# Install PostgreSQL locally, create a database, and set this URL.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/imove"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Random string used to sign JWT tokens. Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-random-secret"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"

# ─── Email (Resend recommended — free 3000/month) ────────────────────────────
# Supports: "smtp" or "resend"
EMAIL_PROVIDER="resend"
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
RESEND_API_KEY="re_1234567890abcdefghijklmnopqrstuv"  # Get from https://resend.com/api-keys
EMAIL_FROM="iMove Partners <hello@myimove.co.uk>"

# ─── Stripe (future — leave blank until ready) ───────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ─── Google Calendar (future — leave blank until ready) ──────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/api/integrations/google/callback"

# ─── Storage (future — leave blank until ready) ──────────────────────────────
# Supports: "local" or "s3"
STORAGE_PROVIDER="local"
STORAGE_LOCAL_DIR="./uploads"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# ─── API Keys (for AI / external integrations) ───────────────────────────────
# Optional pepper added to API key hashing for extra entropy
API_KEY_SECRET="change-me-to-another-random-secret"
