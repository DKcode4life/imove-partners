generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Existing entities (migrated from SQLite) ───────────────────────────────

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password_hash String
  name          String
  role          String // 'admin' | 'partner'
  avatar        String?
  created_at    DateTime @default(now())

  partner              Partner?
  calendar_connections CalendarConnection[]
  integration_tokens   IntegrationToken[]
  change_logs          JobChangeLog[]

  @@map("users")
}

model Partner {
  id              Int      @id @default(autoincrement())
  user_id         Int      @unique
  agency_name     String
  phone           String?
  commission_rate Float    @default(10.0)
  payment_method  String?
  bank_account    String?
  bank_sort_code  String?
  gift_card_email String?
  active          Boolean  @default(true)
  leads_visible   Boolean  @default(true)
  created_at      DateTime @default(now())

  user  User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  leads Lead[]

  @@map("partners")
}

model Lead {
  id                    Int      @id @default(autoincrement())
  partner_id            Int
  client_name           String
  current_address       String
  destination_address   String?
  contact_number        String
  email                 String
  estimated_moving_date String?
  moving_date_type      String?
  move_type             String?
  property_type         String?
  floor_number          String?
  has_lift              Boolean?
  property_size         String?
  notes                 String?
  move_stage            String?
  status                String   @default("New Lead")
  quote_value           Float?
  commission_rate       Float    @default(10.0)
  commission_paid       Boolean  @default(false)
  commission_paid_at    String?
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now()) @updatedAt

  partner  Partner  @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  crm_jobs CrmJob[]

  @@map("leads")
}

model CrmJob {
  id                      Int      @id @default(autoincrement())
  lead_id                 Int?
  customer_id             Int?
  referred_by_customer_id Int?
  // Contact
  full_name               String
  email                   String?
  alt_email               String?
  phone                   String?
  alt_phone               String?
  client_notes            String?
  // Lead / Referral
  lead_source             String?  @default("Direct Enquiry")
  estate_agent_name       String?
  internal_ref            String?
  status                  String   @default("New Lead")
  lost_reason             String?
  lost_notes              String?
  // Move Details — From
  from_line1              String?
  from_line2              String?
  from_city               String?
  from_postcode           String?
  // Move Details — To
  to_line1                String?
  to_line2                String?
  to_city                 String?
  to_postcode             String?
  // Property
  property_type_from      String?
  property_type_to        String?
  bedrooms                String?
  parking_notes           String?
  bedrooms_to             String?
  parking_notes_to        String?
  preferred_move_date     String?
  confirmed_move_date     String?
  flexibility_notes       String?
  // Additional move days (packing, pre-load, delivery, etc.) stored as JSON:
  // [{ id: string, label: string, offset: number }] where offset is signed days
  // relative to the anchor date (confirmed_move_date || preferred_move_date).
  // Negative = before the move, positive = after. The main move day is offset 0
  // and is NOT stored here. Real dates are derived on read so they auto-shift
  // when the confirmed move date changes.
  move_schedule           Json?
  // Survey / Quote
  survey_required         Boolean  @default(false)
  survey_type             String?
  survey_date             String?
  survey_time             String?
  // Planner event auto-created when a survey is scheduled, so the survey shows on
  // the planner/calendar and crew can be assigned. Managed by the survey sync;
  // onDelete SetNull clears this link if the event is deleted on the planner.
  survey_event_id         Int?     @unique
  quote_amount            Float?
  quote_sent_date         String?
  quote_accepted          Boolean  @default(false)
  deposit_required        Boolean  @default(false)
  deposit_paid            Boolean  @default(false)
  // Operations
  internal_notes          String?
  special_handling        String?
  access_restrictions     String?
  inventory_notes         String?
  packing_required        Boolean  @default(false)
  dismantling_required    Boolean  @default(false)
  storage_required        Boolean  @default(false)
  // Property extras
  floor_from              String?
  has_lift_from           Boolean  @default(false)
  prop_type_from_other    String?
  floor_to                String?
  has_lift_to             Boolean  @default(false)
  prop_type_to_other      String?
  // Move type
  move_type               String?
  is_key_worker           Boolean  @default(false)
  // Staff
  assigned_surveyor       String?
  assigned_mover          String?
  assigned_driver         String?
  assigned_vehicle        String?
  // Partner
  partner_commission_rate Float?
  // Survey inventory (stored as JSON: { data, searchData, customRooms, roomPhotos })
  survey_data             Json?
  // QuoteBuilder per-job state (estimateItems, quotationItems, quotationAddons, VAT flags, deposit section)
  quote_state             Json?
  // FurnitureCovers per-job custom edits (CoverItem[])
  covers_state            Json?
  // Per-job planner color override (hex); beats category default
  planner_color           String?
  // Per-job P&L base income (manual; UI prefills a smart suggestion when null)
  pnl_income              Float?
  // Timestamps
  created_at              DateTime @default(now())
  updated_at              DateTime @default(now()) @updatedAt

  lead                Lead?               @relation(fields: [lead_id], references: [id], onDelete: SetNull)
  customer            CrmCustomer?        @relation("customer_jobs", fields: [customer_id], references: [id], onDelete: SetNull)
  referred_by         CrmCustomer?        @relation("referred_jobs", fields: [referred_by_customer_id], references: [id], onDelete: SetNull)
  activities          CrmActivity[]
  planner_assignments PlannerAssignment[]
  quotes              Quote[]
  invoices            Invoice[]
  sent_documents      SentDocument[]
  documents           Document[]
  calendar_events     CalendarEvent[]
  change_logs         JobChangeLog[]
  ledger_lines        JobLedgerLine[]
  survey_event        PlannerEvent?       @relation("job_survey_event", fields: [survey_event_id], references: [id], onDelete: SetNull)

  @@map("crm_jobs")
}

model CrmActivity {
  id         Int      @id @default(autoincrement())
  job_id     Int
  type       String
  note       String?
  created_at DateTime @default(now())

  job CrmJob @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@map("crm_activities")
}

model CrmCustomer {
  id            Int      @id @default(autoincrement())
  full_name     String
  email         String?
  alt_email     String?
  phone         String?
  alt_phone     String?
  address_line1 String?
  address_line2 String?
  city          String?
  postcode      String?
  notes         String?
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  jobs      CrmJob[] @relation("customer_jobs")
  referrals CrmJob[] @relation("referred_jobs")

  @@map("crm_customers")
}

model PlannerAsset {
  id             Int      @id @default(autoincrement())
  type           String // 'staff' | 'vehicle'
  name           String
  role           String?
  phone          String?
  email          String?
  make_model     String?
  registration   String?
  capacity_notes String?
  availability   String   @default("available")
  is_lorry       Boolean  @default(false) // vehicles only — flags HGV/lorry; driver assigned to one earns the lorry-driving bonus
  // Per-staff wage rates (staff assets only). Used by wage-calc as the default
  // for daily / lux earnings — falls back to the company-wide ROLE_DEFAULT_RATE
  // (driver £150 / porter £125) and global lux_hourly_rate when null.
  driver_daily_rate Float?
  porter_daily_rate Float?
  lux_hourly_rate   Float?
  notes          String?
  sort_order     Int      @default(0)
  created_at     DateTime @default(now())

  assignments  PlannerAssignment[]
  wage_periods WagePeriod[]
  time_off     StaffTimeOff[]

  @@map("planner_assets")
}

model PlannerEvent {
  id             Int      @id @default(autoincrement())
  title          String
  category       String   @default("Quick Job")
  customer_name  String?
  contact_number String?
  address        String?
  event_date     String
  event_time     String?
  notes          String?
  contract_id    Int?
  planner_color  String?  // per-event color override (hex), beats contract + category defaults
  pnl_income     Float?   // per-job P&L base income (manual; UI prefills suggestion when null)
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt

  assignments  PlannerAssignment[]
  contract     Contract?           @relation(fields: [contract_id], references: [id], onDelete: SetNull)
  contract_job ContractJob?
  ledger_lines JobLedgerLine[]
  survey_for_job CrmJob?           @relation("job_survey_event")

  @@map("planner_events")
}

model PlannerAssignment {
  id               Int      @id @default(autoincrement())
  asset_id         Int
  job_id           Int?
  event_id         Int?
  assigned_date    String
  assigned_role    String?
  daily_rate       Float?
  vehicle_asset_id Int?
  start_time       String? // "HH:MM" per-assignment start, editable on Staff View grid
  finish_time      String? // "HH:MM" per-assignment finish — shown on Lux days; drives Lux wage calc together with start_time
  wage_override    Float? // manual wage from Staff View — replaces both Lux (hours×rate) and daily-rate calc; lorry bonus is NOT added on top
  notes            String?
  created_at       DateTime @default(now())

  asset PlannerAsset  @relation(fields: [asset_id], references: [id], onDelete: Cascade)
  job   CrmJob?       @relation(fields: [job_id], references: [id], onDelete: Cascade)
  event PlannerEvent? @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@map("planner_assignments")
}

model JobLedgerLine {
  id         Int      @id @default(autoincrement())
  job_id     Int?
  event_id   Int?
  kind       String // 'income' | 'expense'
  label      String
  amount     Float    @default(0)
  sort_order Int      @default(0)
  // Which day this line belongs to: null/'move' = the main move day; otherwise a
  // move_schedule day id (packing, delivery, …). Lets extra-day expenses be
  // entered on their own card while still rolling into the job's total P&L.
  day_key    String?
  created_at DateTime @default(now())

  job   CrmJob?       @relation(fields: [job_id], references: [id], onDelete: Cascade)
  event PlannerEvent? @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@index([job_id])
  @@index([event_id])
  @@map("job_ledger_lines")
}

model StaffTimeOff {
  id         Int      @id @default(autoincrement())
  asset_id   Int
  date       String // YYYY-MM-DD
  reason     String?
  created_at DateTime @default(now())

  asset PlannerAsset @relation(fields: [asset_id], references: [id], onDelete: Cascade)

  @@unique([asset_id, date])
  @@index([date])
  @@map("staff_time_off")
}

model WagePeriod {
  id         Int       @id @default(autoincrement())
  asset_id   Int
  week_start String // YYYY-MM-DD (Monday)
  expenses   Float     @default(0)
  advances   Float     @default(0)
  notes      String?
  paid       Boolean   @default(false)
  paid_at    DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt

  asset PlannerAsset @relation(fields: [asset_id], references: [id], onDelete: Cascade)

  @@unique([asset_id, week_start])
  @@map("wage_periods")
}

// ─── New entities ───────────────────────────────────────────────────────────

model Quote {
  id           Int       @id @default(autoincrement())
  job_id       Int
  quote_number String    @unique
  quote_type   String    @default("fixed") // estimate | fixed
  status       String    @default("draft") // draft | sent | accepted | declined | expired
  subtotal     Float     @default(0)
  tax_rate     Float     @default(20.0)
  tax_amount   Float     @default(0)
  total        Float     @default(0)
  deposit      Float     @default(0)
  valid_until  String?
  notes        String?
  sent_at      DateTime?
  sent_to      String?
  accepted_at  DateTime?
  // Online quote-acceptance fields. accept_token is the unguessable slug in the
  // customer-facing /accept/:token link; it's minted on the first fixed-quote
  // send and reused on re-sends. declared_value is the item value the customer
  // typed for full insurance cover (recorded only — no premium charged).
  // accepted_total is the firm total at the moment of acceptance (mandatory
  // services + whichever optional services the customer selected).
  accept_token   String?  @unique
  declared_value Float?
  accepted_total Float?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now()) @updatedAt

  job      CrmJob      @relation(fields: [job_id], references: [id], onDelete: Cascade)
  items    QuoteItem[]
  invoices Invoice[]

  @@map("quotes")
}

model QuoteItem {
  id          Int     @id @default(autoincrement())
  quote_id    Int
  description String
  quantity    Float   @default(1)
  unit_price  Float   @default(0)
  total       Float   @default(0)
  sort_order  Int     @default(0)
  is_optional Boolean @default(false)
  // Set true when the customer opts into this optional service during online
  // acceptance. Meaningless for mandatory items (they are always included); the
  // "accepted set" is computed as `!is_optional || accepted`.
  accepted    Boolean @default(false)

  quote Quote @relation(fields: [quote_id], references: [id], onDelete: Cascade)

  @@map("quote_items")
}

/// Immutable snapshot written on every successful client send. Freezes the exact
/// email body + amounts + the argument object passed to the PDF generator, so the
/// PDF can be regenerated byte-for-byte on demand. Powers the "Sent to Clients"
/// history list and quote/invoice versioning (each send = one row).
model SentDocument {
  id                Int      @id @default(autoincrement())
  job_id            Int
  doc_type          String // estimate-quote | fixed-quote | deposit-invoice | deposit-receipt | main-invoice | move-receipt | additional-invoice
  reference         String // EST-/iMQ-/DEP-/INV-/ADC- number
  version           Int      @default(1) // per (job_id, doc_type); bumps only on content change
  title             String
  description       String
  to_email          String
  subject           String
  body_html         String // exact rendered email body that was sent
  amount            Float    @default(0)
  total             Float    @default(0)
  deposit           Float    @default(0)
  balance           Float    @default(0)
  content_hash      String // hash of pdf args + subject + body, used for versioning
  pdf_generator     String // 'quote' | 'invoice'
  pdf_args          Json // exact generator args (incl. invoice `mode`)
  source_quote_id   Int?
  source_invoice_id Int?
  sent_at           DateTime @default(now())
  created_at        DateTime @default(now())

  job CrmJob @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@index([job_id])
  @@map("sent_documents")
}

model Invoice {
  id                  Int       @id @default(autoincrement())
  job_id              Int
  quote_id            Int?
  invoice_number      String    @unique
  invoice_type        String    @default("main") // deposit | main
  status              String    @default("draft") // draft | sent | paid | overdue | cancelled
  subtotal            Float     @default(0)
  tax_rate            Float     @default(20.0)
  tax_amount          Float     @default(0)
  total               Float     @default(0)
  due_date            String?
  notes               String?
  sent_at             DateTime?
  sent_to             String?
  paid_at             DateTime?
  // Bank account snapshot — captured at save time so historical invoices
  // remain correct even if the BankAccount row is later edited or deleted.
  bank_account_id     Int?
  bank_account_name   String?
  bank_sort_code      String?
  bank_account_number String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  job          CrmJob        @relation(fields: [job_id], references: [id], onDelete: Cascade)
  quote        Quote?        @relation(fields: [quote_id], references: [id], onDelete: SetNull)
  bank_account BankAccount?  @relation(fields: [bank_account_id], references: [id], onDelete: SetNull)
  items        InvoiceItem[]
  payments     Payment[]

  @@map("invoices")
}

model InvoiceItem {
  id          Int    @id @default(autoincrement())
  invoice_id  Int
  description String
  quantity    Float  @default(1)
  unit_price  Float  @default(0)
  total       Float  @default(0)
  sort_order  Int    @default(0)

  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Payment {
  id                Int      @id @default(autoincrement())
  invoice_id        Int
  amount            Float
  method            String // stripe | bank_transfer | cash | cheque
  stripe_payment_id String?
  reference         String?
  notes             String?
  paid_at           DateTime @default(now())
  created_at        DateTime @default(now())

  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Document {
  id          Int      @id @default(autoincrement())
  job_id      Int
  name        String
  type        String // quote_pdf | invoice_pdf | survey_report | photo | other
  storage_key String
  mime_type   String?
  size_bytes  Int?
  created_at  DateTime @default(now())

  job CrmJob @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@map("documents")
}

model CalendarConnection {
  id               Int       @id @default(autoincrement())
  user_id          Int
  provider         String    @default("google")
  access_token     String?
  refresh_token    String?
  token_expires_at DateTime?
  calendar_id      String?
  enabled          Boolean   @default(true)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now()) @updatedAt

  user   User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  events CalendarEvent[]

  @@map("calendar_connections")
}

model CalendarEvent {
  id            Int       @id @default(autoincrement())
  connection_id Int
  job_id        Int?
  external_id   String?
  title         String
  description   String?
  start_time    DateTime
  end_time      DateTime
  location      String?
  // Discriminates multiple events per job: 'move' for the main move day, or the
  // move_schedule day id for an extra day (packing, delivery, etc.). Lets one job
  // own several calendar events that are upserted/pruned independently.
  slot_key      String?
  synced_at     DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt

  connection CalendarConnection @relation(fields: [connection_id], references: [id], onDelete: Cascade)
  job        CrmJob?            @relation(fields: [job_id], references: [id], onDelete: SetNull)

  @@map("calendar_events")
}

model EmailTemplate {
  id         Int      @id @default(autoincrement())
  name       String
  slug       String   @unique
  subject    String
  body_html  String
  variables  String? // JSON array of variable names e.g. ["customer_name", "quote_total"]
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  sequence_steps EmailSequenceStep[]
  email_logs     EmailLog[]

  @@map("email_templates")
}

model EmailSequence {
  id            Int      @id @default(autoincrement())
  name          String
  trigger_event String // quote_sent | invoice_sent | job_booked | job_completed
  active        Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  steps EmailSequenceStep[]

  @@map("email_sequences")
}

model EmailSequenceStep {
  id               Int     @id @default(autoincrement())
  sequence_id      Int
  step_order       Int
  delay_hours      Int     @default(0)
  template_id      Int?
  subject_override String?
  body_override    String?

  sequence EmailSequence  @relation(fields: [sequence_id], references: [id], onDelete: Cascade)
  template EmailTemplate? @relation(fields: [template_id], references: [id], onDelete: SetNull)

  @@map("email_sequence_steps")
}

model EmailLog {
  id          Int       @id @default(autoincrement())
  job_id      Int?
  to_email    String
  subject     String
  template_id Int?
  status      String    @default("queued") // queued | sent | failed | bounced
  sent_at     DateTime?
  error       String?
  created_at  DateTime  @default(now())

  template EmailTemplate? @relation(fields: [template_id], references: [id], onDelete: SetNull)

  @@map("email_logs")
}

model IntegrationToken {
  id               Int       @id @default(autoincrement())
  user_id          Int
  provider         String
  access_token     String
  refresh_token    String?
  token_expires_at DateTime?
  scopes           String?
  metadata         String? // JSON
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now()) @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, provider])
  @@map("integration_tokens")
}

model WebhookEvent {
  id           Int       @id @default(autoincrement())
  provider     String
  event_type   String
  payload      String // JSON
  status       String    @default("pending") // pending | processed | failed
  processed_at DateTime?
  error        String?
  created_at   DateTime  @default(now())

  @@map("webhook_events")
}

model BackgroundJob {
  id            Int       @id @default(autoincrement())
  type          String
  payload       String // JSON
  status        String    @default("pending") // pending | running | completed | failed | retrying
  priority      Int       @default(0)
  attempts      Int       @default(0)
  max_attempts  Int       @default(3)
  last_error    String?
  scheduled_for DateTime  @default(now())
  started_at    DateTime?
  completed_at  DateTime?
  created_at    DateTime  @default(now())

  @@index([status, scheduled_for])
  @@index([type])
  @@map("background_jobs")
}

// ─── Settings ────────────────────────────────────────────────────────────────

model CompanySetting {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  value      String?
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("company_settings")
}

model BankAccount {
  id             Int      @id @default(autoincrement())
  label          String // friendly name shown in the dropdown — e.g. "iMove Relocations Ltd"
  account_name   String // bank account holder / company name printed on invoice
  sort_code      String
  account_number String
  is_default     Boolean  @default(false)
  sort_order     Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt

  invoices          Invoice[]
  contract_invoices ContractInvoice[]

  @@map("bank_accounts")
}

model JobStatus {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  color      String   @default("#64748b")
  sort_order Int      @default(0)
  created_at DateTime @default(now())

  @@map("job_statuses")
}

model LeadSource {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  sort_order Int      @default(0)
  created_at DateTime @default(now())

  @@map("lead_sources")
}

model MoveType {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  sort_order Int      @default(0)
  created_at DateTime @default(now())

  @@map("move_types")
}

model Contract {
  id            Int      @id @default(autoincrement())
  company_name  String
  contact_name  String?
  email         String?
  office_number String?
  direct_line   String?
  address       String?
  description   String?
  payment_terms String?
  is_lux        Boolean  @default(false) // flags Lux Move contracts so planner assignments use hourly Lux rate instead of daily
  // Overtime billing — independent of is_lux. When overtime_applicable, hours a
  // staff member works past overtime_threshold_hours on a day are billed at
  // overtime_fee £/hour on the weekly invoice (one summed line per day).
  overtime_applicable      Boolean @default(false)
  overtime_fee             Float?  // £ per overtime hour
  overtime_threshold_hours Float   @default(10) // hours/day before overtime starts
  color         String?  // hex color used by the planner for this contract's jobs; overrides category color
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  planner_events    PlannerEvent[]
  items             ContractItem[]
  jobs              ContractJob[]
  contract_invoices ContractInvoice[]

  @@map("contracts")
}

model ContractItem {
  id          Int      @id @default(autoincrement())
  contract_id Int
  name        String
  unit_price  Float    @default(0)
  sort_order  Int      @default(0)
  archived    Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  contract  Contract          @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  job_items ContractJobItem[]

  @@index([contract_id])
  @@map("contract_items")
}

model ContractJob {
  id               Int      @id @default(autoincrement())
  contract_id      Int
  job_date         String // YYYY-MM-DD
  start_time       String? // "HH:MM" — seeds the planner event time so staff drops preset hours
  description      String?
  notes            String?
  men_needed       Int      @default(0)
  vans_needed      Int      @default(0)
  hgv_needed       Int      @default(0)
  planner_event_id Int?     @unique
  invoiced         Boolean  @default(false)
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now()) @updatedAt

  contract      Contract              @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  planner_event PlannerEvent?         @relation(fields: [planner_event_id], references: [id], onDelete: SetNull)
  items         ContractJobItem[]
  invoice_items ContractInvoiceItem[]

  @@index([contract_id, job_date])
  @@map("contract_jobs")
}

model ContractJobItem {
  id               Int    @id @default(autoincrement())
  contract_job_id  Int
  contract_item_id Int?
  description      String
  quantity         Float  @default(1)
  unit_price       Float  @default(0)
  total            Float  @default(0)
  sort_order       Int    @default(0)

  contract_job  ContractJob           @relation(fields: [contract_job_id], references: [id], onDelete: Cascade)
  contract_item ContractItem?         @relation(fields: [contract_item_id], references: [id], onDelete: SetNull)
  invoice_items ContractInvoiceItem[]

  @@index([contract_job_id])
  @@map("contract_job_items")
}

model ContractInvoice {
  id                  Int       @id @default(autoincrement())
  contract_id         Int
  invoice_number      String    @unique
  week_start          String // YYYY-MM-DD (Monday)
  week_end            String // YYYY-MM-DD (Sunday)
  header_description  String?
  status              String    @default("draft") // draft | sent | paid
  subtotal            Float     @default(0)
  tax_rate            Float     @default(20.0)
  tax_amount          Float     @default(0)
  total               Float     @default(0)
  notes               String?
  sent_at             DateTime?
  sent_to             String?
  paid_at             DateTime?
  // Bank account snapshot — see Invoice model for rationale.
  bank_account_id     Int?
  bank_account_name   String?
  bank_sort_code      String?
  bank_account_number String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  contract     Contract              @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  bank_account BankAccount?          @relation(fields: [bank_account_id], references: [id], onDelete: SetNull)
  items        ContractInvoiceItem[]

  @@index([contract_id, week_start])
  @@map("contract_invoices")
}

model ContractInvoiceItem {
  id                          Int    @id @default(autoincrement())
  contract_invoice_id         Int
  source_contract_job_id      Int?
  source_contract_job_item_id Int?
  job_date                    String // YYYY-MM-DD
  description                 String
  quantity                    Float  @default(1)
  unit_price                  Float  @default(0)
  total                       Float  @default(0)
  sort_order                  Int    @default(0)
  is_overtime                 Boolean @default(false) // system-managed per-day overtime line; recomputed on reconcile

  invoice         ContractInvoice  @relation(fields: [contract_invoice_id], references: [id], onDelete: Cascade)
  source_job      ContractJob?     @relation(fields: [source_contract_job_id], references: [id], onDelete: SetNull)
  source_job_item ContractJobItem? @relation(fields: [source_contract_job_item_id], references: [id], onDelete: SetNull)

  @@index([contract_invoice_id])
  @@index([source_contract_job_item_id])
  @@map("contract_invoice_items")
}

// ─── Audit Trail ──────────────────────────────────────────────────────────────

model JobChangeLog {
  id          Int      @id @default(autoincrement())
  job_id      Int
  user_id     Int
  field_name  String // e.g. "status", "from_line1", "notes"
  old_value   String?
  new_value   String?
  change_type String   @default("update") // "create", "update", "delete"
  ip_address  String?
  user_agent  String?
  created_at  DateTime @default(now())

  job  CrmJob @relation(fields: [job_id], references: [id], onDelete: Cascade)
  user User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([job_id])
  @@index([user_id])
  @@index([created_at])
  @@map("job_change_logs")
}

// Partner Portal usage tracking (logins, page views, etc.)
model PartnerActivityLog {
  id         Int      @id @default(autoincrement())
  user_id    Int
  partner_id Int?
  event_type String // "login" | "logout" | "page_view"
  path       String?
  ip_address String?
  user_agent String?
  created_at DateTime @default(now())

  @@index([user_id])
  @@index([partner_id])
  @@index([event_type])
  @@index([created_at])
  @@map("partner_activity_logs")
}

// API Keys for external integrations (AI assistants, third-party systems)
model ApiKey {
  id           Int       @id @default(autoincrement())
  name         String // e.g. "Claude AI Assistant"
  key_prefix   String    @unique // first 8 chars, shown to user (e.g. "imv_a3f8...")
  key_hash     String // bcrypt hash of full key
  scopes       String    @default("crm:read,crm:write")
  is_active    Boolean   @default(true)
  last_used_at DateTime?
  last_used_ip String?
  created_at   DateTime  @default(now())
  expires_at   DateTime?

  @@map("api_keys")
}
